{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prodcraft.dev/schemas/artifacts/course-correction-note.schema.json",
  "title": "Prodcraft Course Correction Note",
  "type": "object",
  "required": [
    "artifact",
    "schema_version",
    "status",
    "source_phase",
    "target_phase",
    "trigger",
    "evidence_refs",
    "blocked_artifact",
    "preserved_constraints",
    "recommended_next_skill",
    "severity",
    "requires_user_reapproval"
  ],
  "properties": {
    "artifact": { "const": "course-correction-note" },
    "schema_version": { "const": "course-correction-note.v1" },
    "status": { "enum": ["draft", "approved"] },
    "source_phase": {
      "enum": [
        "04-implementation",
        "05-quality",
        "07-operations",
        "08-evolution"
      ]
    },
    "target_phase": {
      "enum": [
        "01-specification",
        "02-architecture",
        "03-planning"
      ]
    },
    "trigger": { "type": "string" },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blocked_artifact": { "type": "string" },
    "preserved_constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_next_skill": { "type": "string" },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "requires_user_reapproval": { "type": "boolean" }
  },
  "anyOf": [
    {
      "properties": {
        "source_phase": { "const": "04-implementation" },
        "target_phase": { "const": "01-specification" }
      }
    },
    {
      "properties": {
        "source_phase": { "const": "04-implementation" },
        "target_phase": { "const": "02-architecture" }
      }
    },
    {
      "properties": {
        "source_phase": { "const": "05-quality" },
        "target_phase": { "const": "02-architecture" }
      }
    },
    {
      "properties": {
        "source_phase": { "const": "07-operations" },
        "target_phase": { "const": "02-architecture" }
      }
    },
    {
      "properties": {
        "source_phase": { "const": "07-operations" },
        "target_phase": { "const": "03-planning" }
      }
    },
    {
      "properties": {
        "source_phase": { "const": "08-evolution" },
        "target_phase": { "const": "01-specification" }
      }
    },
    {
      "properties": {
        "source_phase": { "const": "08-evolution" },
        "target_phase": { "const": "02-architecture" }
      }
    },
    {
      "properties": {
        "source_phase": { "const": "08-evolution" },
        "target_phase": { "const": "03-planning" }
      }
    }
  ],
  "additionalProperties": false
}
