{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prodcraft.dev/schemas/artifacts/requirements-doc.schema.json",
  "title": "Prodcraft Requirements Document",
  "type": "object",
  "required": [
    "artifact",
    "schema_version",
    "status",
    "source_language",
    "artifact_record_language",
    "user_presentation_locale",
    "requirements",
    "acceptance_summary"
  ],
  "properties": {
    "artifact": {
      "const": "requirements-doc"
    },
    "schema_version": {
      "const": "requirements-doc.v1"
    },
    "status": {
      "enum": [
        "draft",
        "reviewed",
        "approved"
      ]
    },
    "source_language": {
      "type": "string",
      "pattern": "^([a-z]{2,3}(-[A-Za-z0-9]{1,8})*|mixed)$",
      "description": "BCP-47 primary language tag of the incoming request, or `mixed` for multilingual requests."
    },
    "artifact_record_language": {
      "const": "en"
    },
    "user_presentation_locale": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Za-z0-9]{1,8})*$",
      "description": "BCP-47 language tag used when presenting results to the user."
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_summary": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
