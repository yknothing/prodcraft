{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prodcraft.dev/schemas/artifacts/problem-frame.schema.json",
  "title": "Prodcraft Problem Frame",
  "type": "object",
  "required": [
    "artifact",
    "schema_version",
    "status",
    "source_language",
    "artifact_record_language",
    "user_presentation_locale",
    "problem_statement",
    "recommended_option",
    "next_skill_to_invoke"
  ],
  "properties": {
    "artifact": { "const": "problem-frame" },
    "schema_version": { "const": "problem-frame.v1" },
    "status": { "enum": ["draft", "approved"] },
    "source_language": {
      "oneOf": [
        { "type": "string", "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$" },
        { "const": "mixed" }
      ]
    },
    "artifact_record_language": { "const": "en" },
    "user_presentation_locale": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "problem_statement": { "type": "string" },
    "recommended_option": { "type": "string" },
    "next_skill_to_invoke": {
      "type": "string",
      "pattern": "^pc-[a-z0-9]+(?:-[a-z0-9]+)*$"
    }
  },
  "additionalProperties": false
}
